<mvc:View controllerName="cyclone.layout.example.cyclonelayoutexample.controller.LayoutExampleView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizData="sap.viz.ui5.data"
    xmlns:vizFeeds="sap.viz.ui5.controls.common.feeds"
    xmlns:core="sap.ui.core">

    <Page id="mainPage" showHeader="false" backgroundDesign="Transparent">
        <subHeader>
            <!-- 필터 바 -->
            <OverflowToolbar style="Clear" class="sapUiSmallPaddingBeginEnd">
                <Title text="매출 실적 현황" level="H3" class="sapUiSmallMarginEnd"/>
                <ToolbarSeparator/>
                <Label text="사업부" design="Bold" class="sapUiSmallMarginEnd"/>
                <Select id="selDivision" width="110px" class="sapUiTinyMarginEnd" change="onFilterChange">
                    <items>
                        <core:Item key="" text="전체"/>
                        <core:Item key="B2B" text="B2B"/>
                        <core:Item key="B2C" text="B2C"/>
                        <core:Item key="수출" text="수출"/>
                    </items>
                </Select>
                <Label text="담당자" design="Bold" class="sapUiSmallMarginEnd"/>
                <Select id="selRep" width="100px" class="sapUiTinyMarginEnd" change="onFilterChange">
                    <items>
                        <core:Item key="" text="전체"/>
                        <core:Item key="김민준" text="김민준"/>
                        <core:Item key="이서연" text="이서연"/>
                        <core:Item key="박지호" text="박지호"/>
                        <core:Item key="최유나" text="최유나"/>
                        <core:Item key="정승우" text="정승우"/>
                        <core:Item key="한소희" text="한소희"/>
                    </items>
                </Select>
                <SearchField id="sfSearch" width="180px" liveChange="onLiveSearch" placeholder="거래처명 검색"/>
                <ToolbarSpacer/>
                <Button text="초기화" icon="sap-icon://clear-filter" press="onReset" type="Ghost"/>
                <Button text="내보내기" icon="sap-icon://excel-attachment" press="onExport" type="Ghost"/>
            </OverflowToolbar>
        </subHeader>

        <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">

            <!-- KPI 스트립 (2개) -->
            <core:HTML id="kpiStrip" content="{view>/kpiHtml}"/>

            <!-- 차트 영역 -->
            <Panel id="chartPanel" class="clChartArea sapUiMediumMarginBottom" expandable="false">
                <headerToolbar>
                    <Toolbar style="Clear">
                        <Title text="사업부별 매출 현황" level="H5"/>
                        <Text id="chartHint" text="  ↑  막대를 클릭하면 아래 테이블이 자동 필터됩니다" class="clChartHint"/>
                        <ToolbarSpacer/>
                        <Button id="btnClearChart" text="선택 해제" icon="sap-icon://decline"
                                visible="{= !!${view>/chartSelection} }"
                                press="onClearChartSelection" type="Ghost" class="clClearBtn"/>
                    </Toolbar>
                </headerToolbar>
                <viz:VizFrame id="divisionChart" vizType="column" height="260px" width="100%"
                              uiConfig="{applicationSet:'fiori'}"
                              selectData="onChartSelect"
                              deselectData="onChartDeselect"
                              vizProperties="{title:{visible:false},legend:{visible:true,position:'bottom'},plotArea:{dataLabel:{visible:true},colorPalette:['#3b66d4','#8cb0f0']},categoryAxis:{title:{visible:false}},valueAxis:{title:{text:'억원'}},interaction:{selectability:{mode:'single'}}}">
                    <viz:dataset>
                        <vizData:FlattenedDataset data="{view>/divisionData}">
                            <vizData:dimensions>
                                <vizData:DimensionDefinition name="사업부" value="{division}"/>
                            </vizData:dimensions>
                            <vizData:measures>
                                <vizData:MeasureDefinition name="매출액(억)" value="{revenue}"/>
                                <vizData:MeasureDefinition name="목표(억)"   value="{target}"/>
                            </vizData:measures>
                        </vizData:FlattenedDataset>
                    </viz:dataset>
                    <viz:feeds>
                        <vizFeeds:FeedItem uid="valueAxis"    type="Measure"   values="매출액(억),목표(억)"/>
                        <vizFeeds:FeedItem uid="categoryAxis" type="Dimension" values="사업부"/>
                    </viz:feeds>
                </viz:VizFrame>
            </Panel>

            <!-- 테이블 -->
            <Panel class="clMainTable" expandable="false">
                <headerToolbar>
                    <OverflowToolbar style="Clear">
                        <Title text="거래처별 매출 실적" level="H5"/>
                        <core:HTML id="filterTag" content="{view>/filterTagHtml}" class="sapUiSmallMarginBegin"/>
                        <ToolbarSpacer/>
                        <Text text="{= ${view>/salesList/length} + '건'}" class="sapUiSmallMarginEnd"/>
                    </OverflowToolbar>
                </headerToolbar>
                <Table id="salesTable"
                       items="{view>/salesList}"
                       growing="true" growingThreshold="8"
                       noDataText="조회 결과가 없습니다."
                       sticky="ColumnHeaders">
                    <columns>
                        <Column width="3.5em"><Text text="순위"/></Column>
                        <Column><Text text="거래처"/></Column>
                        <Column width="5em"><Text text="사업부"/></Column>
                        <Column width="10em" hAlign="End"><Text text="매출액"/></Column>
                        <Column width="6em" hAlign="Center"><Text text="전월비"/></Column>
                        <Column width="10em"><Text text="달성률"/></Column>
                        <Column width="6em" hAlign="Center"><Text text="상태"/></Column>
                        <Column width="6em"><Text text="담당자"/></Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Navigation" press="onRowPress">
                            <cells>
                                <Text text="{view>rank}"/>
                                <VBox>
                                    <Text text="{view>customerName}" wrapping="false"/>
                                    <Text text="{view>customerNo}" class="sapUiTinyMarginTop clKpiLabel" wrapping="false"/>
                                </VBox>
                                <Text text="{view>division}"/>
                                <Text text="{parts:['view>revenue','view>currency'], formatter:'.fmtAmount'}"/>
                                <ObjectStatus
                                    text="{parts:['view>growthRate'], formatter:'.fmtGrowth'}"
                                    state="{parts:['view>growthRate'], formatter:'.fmtGrowthState'}"/>
                                <ProgressIndicator
                                    percentValue="{view>achieveRate}"
                                    displayValue="{= ${view>achieveRate} + '%'}"
                                    state="{parts:['view>achieveRate'], formatter:'.fmtAchieveState'}"
                                    width="100%"/>
                                <core:HTML content="{parts:['view>status'], formatter:'.fmtStatusBadge'}"/>
                                <Text text="{view>salesRep}"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </Panel>

        </VBox>
    </Page>
</mvc:View>
