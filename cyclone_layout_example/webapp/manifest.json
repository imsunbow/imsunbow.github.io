{
  "_version": "1.81.0",
  "sap.app": {
    "id": "cyclone.layout.example.cyclonelayoutexample",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.20.2",
      "toolsId": "54adabac-7532-4155-b10a-4cd2ca6f5dbf"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.148.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.viz": {},
        "sap.ui.layout": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "cyclone.layout.example.cyclonelayoutexample.i18n.i18n"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "cyclone.layout.example.cyclonelayoutexample.view",
        "async": true,
        "viewPath": "cyclone.layout.example.cyclonelayoutexample.view"
      },
      "routes": [
        {
          "name": "RouteLayoutExampleView",
          "pattern": ":?query:",
          "target": [
            "TargetLayoutExampleView"
          ]
        }
      ],
      "targets": {
        "TargetLayoutExampleView": {
          "id": "LayoutExampleView",
          "name": "LayoutExampleView"
        }
      }
    },
    "rootView": {
      "viewName": "cyclone.layout.example.cyclonelayoutexample.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}
