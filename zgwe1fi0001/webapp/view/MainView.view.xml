<mvc:View
  controllerName="zgwe1fi0001.zgwe1fi0001.controller.MainView"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:l="sap.ui.layout"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core"
  xmlns:mc="sap.suite.ui.microchart">

  <SplitApp id="idSplitApp">

    <masterPages>
      <Page title="임시전표 결재" icon="sap-icon://approvals">

        <IconTabBar id="idIconTabBar"
                    select="onFilterSelect"
                    selectedKey="wait"
                    headerMode="Inline"
                    expandable="false"
                    backgroundDesign="Transparent">
          <items>
            <IconTabFilter key="all"    text="전체"      icon="sap-icon://list" />
            <IconTabFilter key="wait"   text="결재 대기" icon="sap-icon://alert"   iconColor="Critical" />
            <IconTabFilter key="done"   text="결재 완료" icon="sap-icon://accept"  iconColor="Positive" />
            <IconTabFilter key="reject" text="반려"      icon="sap-icon://decline" iconColor="Negative" />
          </items>

          <content>
            <List id="idList"
                  items="{/ApprovalHeaderSet}"
                  growing="true"
                  growingThreshold="30"
                  noDataText="조회된 전표가 없습니다."
                  backgroundDesign="Transparent"
                  updateFinished="onListUpdateFinished">
              <ObjectListItem
                title="{Belnr}"
                intro="{Ltext}"
                number="{
                  path: 'Bldat',
                  type: 'sap.ui.model.type.Date',
                  formatOptions: { pattern: 'yyyy-MM-dd', strictParsing: true }
                }"
                numberUnit="증빙일"
                type="Active"
                press="onItemPress"
                icon="{= ${Status} === 'D' ? 'sap-icon://pending' : ${Status} === 'P' ? 'sap-icon://accept' : 'sap-icon://decline'}"
                iconDensityAware="false">
                <attributes>
                  <ObjectAttribute text="{CompName}" />
                  <ObjectAttribute text="{= ${HeaderTxt} ? ${HeaderTxt} : '-'}" />
                </attributes>
                <firstStatus>
                  <ObjectStatus
                    text="{= ${Status} === 'D' ? '결재 대기' : ${Status} === 'P' ? '결재 완료' : '반려'}"
                    state="{= ${Status} === 'D' ? 'Warning' : ${Status} === 'P' ? 'Success' : 'Error'}"
                    inverted="true" />
                </firstStatus>
              </ObjectListItem>
            </List>
          </content>
        </IconTabBar>

        <footer>
          <OverflowToolbar>
            <ToolbarSpacer />
            <Button text="일괄 결재"
                    type="Accept"
                    icon="sap-icon://multi-select"
                    press="onApproveAll" />
          </OverflowToolbar>
        </footer>
      </Page>
    </masterPages>

    <detailPages>

      <Page id="idEmptyPage" title="결재 현황 대시보드" showHeader="true">

        <VBox justifyContent="Center"
              alignItems="Center"
              height="100%"
              class="sapUiLargeMargin">

          <core:Icon src="sap-icon://analytics"
                     size="4rem"
                     color="#107e3e" />

         <Text text="하단 목록에서 결재할 전표를 선택하면 상세 내역이 표시됩니다."
               textAlign="Initial"
               class="sapUiLargeMarginTop" />

          <Title text="임시전표 결재 현황"
                 level="H3"
                 class="sapUiMediumMarginTop sapUiMediumMarginBottom" />

          <VBox displayInline="true" width="700px" height="900px">
            <mc:InteractiveDonutChart id="idDashboardChart" 
                                       displayedSegments="3" 
                                       selectionChanged="onChartSelectionChanged">
              <mc:segments>
                <mc:InteractiveDonutChartSegment label="결재 대기" value="{chart>/WaitCount}" color="Critical" />
                <mc:InteractiveDonutChartSegment label="결재 완료" value="{chart>/DoneCount}" color="Good" />
                <mc:InteractiveDonutChartSegment label="반려"     value="{chart>/RejectCount}" color="Error" />
              </mc:segments>
            </mc:InteractiveDonutChart>
          </VBox>

          
        </VBox>

      </Page>

      <Page id="idDetailPage" title="전표 항목">
        
        <VBox class="sapUiSmallMargin">
          <FlexBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiTinyMarginBottom">
            <HBox alignItems="Center">
              <core:Icon src="{= ${Status} === 'D' ? 'sap-icon://pending' : ${Status} === 'P' ? 'sap-icon://accept' : 'sap-icon://decline'}"
                         size="2.5rem"
                         class="sapUiSmallMarginEnd"
                         color="{= ${Status} === 'D' ? '#E69A00' : ${Status} === 'P' ? '#107E3E' : '#BB0000'}" />
              <VBox>
                <Text text="{Ltext}" class="sapUiTinyMarginBottom" />
                <Title text="{Belnr}" level="H2" />
              </VBox>
            </HBox>
            
            <VBox alignItems="End">
              <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                <Label text="거래처 번호:" class="sapUiTinyMarginEnd" />
                <Text text="{PartnerNo}" />
              </HBox>
              <HBox>
                <ObjectStatus text="{= ${Status} === 'D' ? '결재 대기' : ${Status} === 'P' ? '결재 완료' : '반려'}"
                              state="{= ${Status} === 'D' ? 'Warning' : ${Status} === 'P' ? 'Success' : 'Error'}"
                              inverted="true"
                              class="sapUiTinyMarginEnd" />
                <ObjectStatus title="실제전표번호"
                              text="{= ${ActBelnr} ? ${ActBelnr} : '미생성'}"
                              state="{= ${ActBelnr} ? 'Success' : 'None'}" />
              </HBox>
            </VBox>
          </FlexBox>

          <form:SimpleForm editable="false"
                           layout="ResponsiveLayout"
                           labelSpanXL="3" labelSpanL="3" labelSpanM="4" labelSpanS="12"
                           adjustLabelSpan="false"
                           emptySpanXL="0" emptySpanL="0" emptySpanM="0" emptySpanS="0"
                           columnsXL="2" columnsL="2" columnsM="2" singleContainerFullSize="false">
            <form:content>
              <core:Title text="기본 정보" />
              <Label text="거래처명" />
              <Text text="{CompName}" wrapping="true" /> 
              
              <Label text="적요" />
              <Text text="{= ${HeaderTxt} ? ${HeaderTxt} : '-'}" wrapping="true" />

              <core:Title text="날짜 정보" />
              <Label text="증빙일" />
              <Text text="{
                path: 'Bldat',
                type: 'sap.ui.model.type.Date',
                formatOptions: { pattern: 'yyyy-MM-dd', strictParsing: true }
              }"/>

              <Label text="전기일" />
              <Text text="{
                path: 'Budat',
                type: 'sap.ui.model.type.Date',
                formatOptions: { pattern: 'yyyy-MM-dd', strictParsing: true }
              }" />
            </form:content>
          </form:SimpleForm>
        </VBox>

        <MessageStrip
          text="반려 사유: {ReasonTxt}"
          type="Error"
          showIcon="true"
          showCloseButton="false"
          class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom"
          visible="{= ${Status} === 'J'}" />

        <Panel expandable="false" expanded="true" class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom" backgroundDesign="Transparent">
          <headerToolbar>
            <OverflowToolbar>
              <core:Icon src="sap-icon://table-view" class="sapUiTinyMarginEnd" />
              <Title text="전표 항목 상세" level="H4" />
              <ToolbarSpacer />
              <ObjectStatus text="{= ${ItemSet}/length > 0 ? ${ItemSet}/length + '건' : ''}" />
            </OverflowToolbar>
          </headerToolbar>

          <Table id="idItemTable"
                 items="{ItemSet}"
                 alternateRowColors="true"
                 sticky="ColumnHeaders"
                 noDataText="전표 항목이 없습니다.">
            <columns>
              <Column width="6rem"  hAlign="Center"><Text text="항목번호" /></Column>
              <Column width="6rem"  hAlign="Center"><Text text="차/대변" /></Column>
              <Column width="8rem"><Text text="계정과목" /></Column>
              <Column><Text text="계정명" /></Column>
              <Column width="10rem" hAlign="End"><Text text="금액" /></Column>
              <Column width="5rem"  hAlign="Center"><Text text="통화" /></Column>
            </columns>
            <items>
              <ColumnListItem type="Inactive" highlight="{= ${Shkzg} === 'S' ? 'Information' : 'Warning'}">
                <Text text="{Buzei}" />
                <ObjectStatus text="{= ${Shkzg} === 'S' ? '차변' : '대변'}" state="{= ${Shkzg} === 'S' ? 'Information' : 'Warning'}" icon="{= ${Shkzg} === 'S' ? 'sap-icon://arrow-right' : 'sap-icon://arrow-left'}" inverted="true" />
                <ObjectIdentifier text="{Hkont}" />
                <Text text="{Txt20}" />
                <ObjectNumber number="{OpenAmt}" unit="{Waers}" state="{= ${Shkzg} === 'S' ? 'Information' : 'Warning'}" emphasized="true" />
                <Text text="{Waers}" />
              </ColumnListItem>
            </items>
          </Table>
        </Panel>

        <footer>
          <OverflowToolbar>
            <ToolbarSpacer />
            <Button text="결재" type="Accept" icon="sap-icon://accept" press="onApprove" />
            <Button text="반려" type="Reject" icon="sap-icon://decline" press="onReject" />
          </OverflowToolbar>
        </footer>
      </Page>
    </detailPages>

  </SplitApp>
</mvc:View>