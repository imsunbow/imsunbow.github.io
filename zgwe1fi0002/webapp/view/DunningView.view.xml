<mvc:View controllerName="zgwe1fi0002.zgwe1fi0002.controller.DunningView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.f"
    xmlns:table="sap.ui.table">

    <Page id="page" title="[FI] 독촉 내역" showNavButton="true" navButtonPress="onNavBack">

        <!-- 필터 영역 -->
        <Panel id="filterPanel" headerText="조회 조건" expandable="true" expanded="true"
               class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
            <content>
                <Toolbar id="filterToolbar" style="Clear">
                    <Label text="고객사 번호" labelFor="inputPartner" design="Bold"/>
                    <Input id="inputPartner" placeholder="고객번호" width="160px" submit="onSearch"
                   showValueHelp="true" valueHelpRequest="onPartnerValueHelp"/>
                    <ToolbarSeparator/>
                    <Label text="회사코드" labelFor="inputBukrs" design="Bold"/>
                    <Input id="inputBukrs" placeholder="회사코드" width="80px"/>
                    <ToolbarSeparator/>
                    <Label text="연체일" labelFor="inputOverdue" design="Bold"/>
                    <Input id="inputOverdue" placeholder="연체일" width="80px" type="Number"/>
                    <ToolbarSpacer/>
                    <Button text="조회" icon="sap-icon://search" press="onSearch" type="Emphasized"/>
                    <Button text="초기화" icon="sap-icon://refresh" press="onReset"/>
                </Toolbar>
            </content>
        </Panel>

        <!-- KPI 카드 영역 -->
        <HBox id="kpiBox" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop sapUiSmallMarginBottom kpiBoxWrap">
            <GenericTile id="tileCount" header="미결 독촉건수" subheader="건"
                         frameType="TwoByOne" sizeBehavior="Responsive" class="sapUiTinyMarginEnd">
                <layoutData><FlexItemData growFactor="1" shrinkFactor="1" baseSize="0%"/></layoutData>
                <TileContent>
                    <NumericContent value="{view>/totalCount}" withMargin="false"/>
                </TileContent>
            </GenericTile>
            <GenericTile id="tileAmount" header="총 미납액" subheader="{view>/totalAmountScale}원"
                         frameType="TwoByOne" sizeBehavior="Responsive" class="sapUiTinyMarginEnd">
                <layoutData><FlexItemData growFactor="1" shrinkFactor="1" baseSize="0%" /></layoutData>
                <TileContent>
                    <NumericContent value="{view>/totalAmount}" scale="{view>/totalAmountScale}" withMargin="false"/>
                </TileContent>
            </GenericTile>
            <GenericTile id="tileMaxOverdue" header="최대 연체일" subheader="일"
                         frameType="TwoByOne" sizeBehavior="Responsive" class="sapUiTinyMarginEnd">
                <layoutData><FlexItemData growFactor="1" shrinkFactor="1" baseSize="0%"/></layoutData>
                <TileContent>
                    <NumericContent value="{view>/maxOverdue}" valueColor="Error" withMargin="false"/>
                </TileContent>
            </GenericTile>
            <GenericTile id="tileAvgOverdue" header="평균 연체일" subheader="일"
                         frameType="TwoByOne" sizeBehavior="Responsive">
                <layoutData><FlexItemData growFactor="1" shrinkFactor="1" baseSize="0%"/></layoutData>
                <TileContent>
                    <NumericContent value="{view>/avgOverdue}" valueColor="Critical" withMargin="false"/>
                </TileContent>
            </GenericTile>
        </HBox>

        <!-- 독촉 거래내역 테이블 -->
        <Table id="dunningTable"
               items="{path: '/DunningSet', parameters: {operationMode: 'Client', select: 'Bukrs,Belnr,Gjahr,PartnerNo,CompName,Budat,DueDate,OverdueDays,Skfor,Waers,ClearStatus,Lprio,Zterm,ZtermDays,Klimk'}}"
               growing="true"
               growingThreshold="50"
               mode="MultiSelect"
               noDataText="{view>/noDataText}"
               sticky="HeaderToolbar,ColumnHeaders"
               class="sapUiSmallMarginBeginEnd">

            <headerToolbar>
                <OverflowToolbar>
                    <Title text="지급독촉 거래내역" level="H3"/>
                    <Text text="(행 클릭 시 독촉장 조회)" class="sapUiSmallMarginBegin sapThemeTextColor" wrapping="false"/>
                    <ToolbarSpacer/>
                    <Button text="메일 발송"     icon="sap-icon://email"    press="onSendMail"    type="Ghost">
                        <layoutData><OverflowToolbarLayoutData priority="NeverOverflow"/></layoutData>
                    </Button>
                    <Button text="엑셀 다운로드" icon="sap-icon://download" press="onExcelExport" type="Ghost">
                        <layoutData><OverflowToolbarLayoutData priority="NeverOverflow"/></layoutData>
                    </Button>
                </OverflowToolbar>
            </headerToolbar>

            <columns>
                <Column id="colBukrs"   width="5em" ><Text text="회사코드"/></Column>
                <Column id="colBelnr"   width="9em" ><Text text="전표번호"/></Column>
                <Column id="colGjahr"   width="5em" ><Text text="회계연도"/></Column>
                <Column id="colPartner" width="8em" ><Text text="BP번호"  /></Column>
                <Column id="colComp"                ><Text text="거래처명"/></Column>
                <Column id="colDueDate" width="8em" ><Text text="만기일"  /></Column>
                <Column id="colOverdue" width="7em"  hAlign="End"><Text text="연체일"/></Column>
                <Column id="colSkfor"   width="10em" hAlign="End"><Text text="미납금액"/></Column>
                <Column id="colStatus"  width="7em"  hAlign="Center"><Text text="반제상태"/></Column>
                <Column id="colLprio"   width="5em"  hAlign="Center"><Text text="등급"/></Column>
                <Column id="colBudat"   width="8em" ><Text text="전기일"  /></Column>
                <Column id="colZterm"   width="7em" ><Text text="지불조건"/></Column>
            </columns>

            <items>
                <ColumnListItem type="Navigation" press="onItemPress">
                    <!-- 회사코드 -->
                    <Text text="{Bukrs}"/>
                    <!-- 전표번호 -->
                    <Text text="{Belnr}"/>
                    <!-- 회계연도 -->
                    <Text text="{Gjahr}"/>
                    <!-- BP번호 -->
                    <Text text="{PartnerNo}"/>
                    <!-- 거래처명 -->
                    <Text text="{CompName}"/>
                    <!-- 만기일 -->
                    <Text text="{path: 'DueDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'yyyy-MM-dd'}}"/>
                    <!-- 연체일 (색상 강조) -->
                    <ObjectNumber
                        number="{OverdueDays}"
                        unit="일"
                        state="{path: 'OverdueDays', formatter: '.formatter.overdueDaysState'}"/>
                    <!-- 미납금액 -->
                    <Text text="{parts: [{path: 'Skfor'}, {path: 'Waers'}], formatter: '.formatter.formatAmount'}"/>
                    <!-- 반제상태 -->
                    <ObjectStatus
                        text="{path: 'ClearStatus', formatter: '.formatter.clearStatusText'}"
                        state="{path: 'ClearStatus', formatter: '.formatter.clearStatusState'}"
                        icon="{path: 'ClearStatus', formatter: '.formatter.clearStatusIcon'}"/>
                    <!-- 등급 -->
                    <ObjectStatus
                        text="{path: 'Lprio', formatter: '.formatter.lprioText'}"
                        state="{path: 'Lprio', formatter: '.formatter.lprioState'}"/>
                    <!-- 전기일 -->
                    <Text text="{path: 'Budat', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'yyyy-MM-dd'}}"/>
                    <!-- 지불조건 -->
                    <Text text="{Zterm}"/>
                </ColumnListItem>
            </items>

        </Table>

    </Page>
</mvc:View>
