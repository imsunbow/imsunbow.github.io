<mvc:View controllerName="zgwe1fi0002.zgwe1fi0002.controller.OverviewView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizData="sap.viz.ui5.data"
    xmlns:vizFeeds="sap.viz.ui5.controls.common.feeds">

    <Page id="overviewPage" title="[FI] 매출 현황" showNavButton="false">

        <!-- 필터 영역 -->
        <Panel id="overviewFilterPanel" headerText="조회 조건" expandable="true" expanded="true"
               class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
            <content>
                <Toolbar style="Clear">
                    <Label text="고객사 번호" design="Bold"/>
                    <Input id="ovInputPartner" placeholder="고객번호" width="160px"
                           showValueHelp="true" valueHelpRequest="onOverviewPartnerValueHelp" submit="onOverviewSearch"/>
                    <ToolbarSeparator/>
                    <Label text="회사코드" design="Bold"/>
                    <Input id="ovInputBukrs" placeholder="회사코드" width="80px" submit="onOverviewSearch"/>
                    <ToolbarSpacer/>
                    <Button text="조회" icon="sap-icon://search" press="onOverviewSearch" type="Emphasized"/>
                    <Button text="초기화" icon="sap-icon://refresh" press="onOverviewReset"/>
                </Toolbar>
            </content>
        </Panel>

        <!-- KPI 타일 -->
        <HBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop sapUiSmallMarginBottom kpiBoxWrap">
            <GenericTile header="미결 건수" subheader="건"
                         frameType="TwoByOne" sizeBehavior="Responsive" class="sapUiTinyMarginEnd"
                         press="onOpenMigyeolDialog">
                <layoutData><FlexItemData growFactor="1" shrinkFactor="1" baseSize="0%"/></layoutData>
                <TileContent>
                    <NumericContent value="{overview>/kpi/openCount}" withMargin="false"/>
                </TileContent>
            </GenericTile>
            <GenericTile header="총 미납액" subheader="원"
                         frameType="TwoByOne" sizeBehavior="Responsive" class="sapUiTinyMarginEnd">
                <layoutData><FlexItemData growFactor="1" shrinkFactor="1" baseSize="0%"/></layoutData>
                <TileContent>
                    <NumericContent value="{overview>/kpi/totalOpen}" scale="{overview>/kpi/totalOpenScale}" valueColor="Critical" withMargin="false"/>
                </TileContent>
            </GenericTile>
            <GenericTile header="90일 초과" subheader="건"
                         frameType="TwoByOne" sizeBehavior="Responsive" class="sapUiTinyMarginEnd">
                <layoutData><FlexItemData growFactor="1" shrinkFactor="1" baseSize="0%"/></layoutData>
                <TileContent>
                    <NumericContent value="{overview>/kpi/over90Count}" valueColor="Error" withMargin="false"/>
                </TileContent>
            </GenericTile>
            <GenericTile header="평균 연체일" subheader="일"
                         frameType="TwoByOne" sizeBehavior="Responsive">
                <layoutData><FlexItemData growFactor="1" shrinkFactor="1" baseSize="0%"/></layoutData>
                <TileContent>
                    <NumericContent value="{overview>/kpi/avgOverdue}" valueColor="Critical" withMargin="false"/>
                </TileContent>
            </GenericTile>
        </HBox>

        <!-- 차트 영역 -->
        <HBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom" alignItems="Stretch">

            <!-- 연체구간별 건수 바차트 -->
            <Panel headerText="연체 구간별 건수" class="sapUiTinyMarginEnd overviewChartPanel">
                <layoutData><FlexItemData growFactor="3" shrinkFactor="1" baseSize="0%"/></layoutData>
                <viz:VizFrame id="barChart" vizType="bar" height="280px" width="100%"
                              uiConfig="{applicationSet:'fiori'}"
                              vizProperties="{title:{text:'연체 구간별 미결 건수',visible:true}}">
                    <viz:dataset>
                        <vizData:FlattenedDataset data="{overview>/overdueRanges}">
                            <vizData:dimensions>
                                <vizData:DimensionDefinition name="구간" value="{label}"/>
                            </vizData:dimensions>
                            <vizData:measures>
                                <vizData:MeasureDefinition name="건수" value="{count}"/>
                            </vizData:measures>
                        </vizData:FlattenedDataset>
                    </viz:dataset>
                    <viz:feeds>
                        <vizFeeds:FeedItem id="barValueAxis" uid="valueAxis" type="Measure" values="건수"/>
                        <vizFeeds:FeedItem id="barCategoryAxis" uid="categoryAxis" type="Dimension" values="구간"/>
                    </viz:feeds>
                </viz:VizFrame>
            </Panel>

            <!-- 반제상태 도넛차트 -->
            <Panel headerText="반제 상태 비율" class="overviewChartPanel">
                <layoutData><FlexItemData growFactor="2" shrinkFactor="1" baseSize="0%"/></layoutData>
                <viz:VizFrame id="donutChart" vizType="donut" height="280px" width="100%"
                              uiConfig="{applicationSet:'fiori'}"
                              vizProperties="{title:{text:'반제 상태 비율',visible:true}}">
                    <viz:dataset>
                        <vizData:FlattenedDataset data="{overview>/clearStatus}">
                            <vizData:dimensions>
                                <vizData:DimensionDefinition name="상태" value="{label}"/>
                            </vizData:dimensions>
                            <vizData:measures>
                                <vizData:MeasureDefinition name="건수" value="{count}"/>
                            </vizData:measures>
                        </vizData:FlattenedDataset>
                    </viz:dataset>
                    <viz:feeds>
                        <vizFeeds:FeedItem id="donutSize" uid="size" type="Measure" values="건수"/>
                        <vizFeeds:FeedItem id="donutColor" uid="color" type="Dimension" values="상태"/>
                    </viz:feeds>
                </viz:VizFrame>
            </Panel>

        </HBox>

        <!-- 독촉 내역 바로가기 -->
        <HBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom">
            <GenericTile header="미결 독촉 내역"
                         subheader="클릭하여 상세 내역으로 이동"
                         frameType="TwoByOne"
                         sizeBehavior="Responsive"
                         press="onNavToDunning"
                         class="overviewNavTile">
                <layoutData><FlexItemData growFactor="1" shrinkFactor="0" baseSize="0%"/></layoutData>
                <TileContent footer="상세 내역 →">
                    <NumericContent value="{overview>/kpi/overdueCount}" scale="건" valueColor="Critical" withMargin="false"/>
                </TileContent>
            </GenericTile>
        </HBox>

    </Page>
</mvc:View>
