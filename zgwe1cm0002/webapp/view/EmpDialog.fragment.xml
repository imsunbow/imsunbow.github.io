<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog id="empDialog"
        title="{viewModel>/dialogTitle}"
        resizable="true"
        draggable="true"
        contentWidth="400px">

        <content>
            <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom" width="100%">

                <Label text="사원명" required="true" class="sapUiSmallMarginTop"/>
                <Input id="inpEmpName"
                    value="{viewModel>/editEmployee/EmpName}"
                    maxLength="20"
                    placeholder="사원명"/>

                <Label text="부서번호" required="true" class="sapUiSmallMarginTop"/>
                <Input id="inpDeptNo"
                    value="{viewModel>/editEmployee/DeptNo}"
                    maxLength="8"
                    placeholder="부서번호"/>

                <Label text="부서이름" class="sapUiSmallMarginTop"/>
                <Input id="inpDeptName"
                    value="{viewModel>/editEmployee/DeptName}"
                    maxLength="25"
                    placeholder="부서이름"/>

                <Label text="코스트센터" required="true" class="sapUiSmallMarginTop"/>
                <Input id="inpKostl"
                    value="{viewModel>/editEmployee/Kostl}"
                    maxLength="10"
                    placeholder="코스트센터"/>

                <Label text="관리회계 영역" class="sapUiSmallMarginTop"/>
                <Input id="inpKokrs"
                    value="{viewModel>/editEmployee/Kokrs}"
                    maxLength="4"
                    placeholder="관리회계 영역 (최대 4자)"/>

                <Label text="직급" class="sapUiSmallMarginTop"/>
                <Input id="inpRank"
                    value="{viewModel>/editEmployee/Rank}"
                    maxLength="2"
                    placeholder="직급 코드 (최대 2자)"/>

                <Label text="입사연도" class="sapUiSmallMarginTop"/>
                <Input id="inpEntYear"
                    value="{viewModel>/editEmployee/EntYear}"
                    maxLength="4"
                    placeholder="YYYY"/>

                <Label text="급여" class="sapUiSmallMarginTop"/>
                <Input id="inpRankPay"
                    value="{viewModel>/editEmployee/RankPay}"
                    type="Number"
                    placeholder="0"/>

                <Label text="통화키" class="sapUiSmallMarginTop"/>
                <Input id="inpWaers"
                    value="{viewModel>/editEmployee/Waers}"
                    maxLength="5"
                    placeholder="KRW"/>

            </VBox>
        </content>

        <buttons>
            <Button text="확인" type="Emphasized" press="onConfirmEmpDialog"/>
            <Button text="취소"                   press="onCancelEmpDialog"/>
        </buttons>

    </Dialog>
</core:FragmentDefinition>
